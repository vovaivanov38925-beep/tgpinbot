// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid()) @map("id")
  telegramId     String   @unique @map("telegram_id")
  telegramChatId String?  @unique @map("telegram_chat_id")
  username       String?  @map("username")
  firstName      String?  @map("first_name")
  lastName       String?  @map("last_name")
  photoUrl       String?  @map("photo_url")
  points         Int      @default(0) @map("points")
  level          Int      @default(1) @map("level")
  isPremium      Boolean  @default(false) @map("is_premium")
  premiumExpiry  DateTime? @map("premium_expiry")
  botState       String?  @map("bot_state")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  pins               Pin[]
  tasks              Task[]
  achievements       UserAchievement[]
  notificationSettings NotificationSettings?
  pinterestBoards    PinterestBoard[]
  supportTickets     SupportTicket[]
  scraperTasks       ScraperTask[]
  subscriptions      Subscription[]

  @@map("users")
}

model NotificationSettings {
  id                    String   @id @default(cuid()) @map("id")
  userId                String   @unique @map("user_id")

  taskReminders         Boolean  @default(true) @map("task_reminders")
  newPins               Boolean  @default(true) @map("new_pins")
  achievements          Boolean  @default(true) @map("achievements")
  levelUp               Boolean  @default(true) @map("level_up")
  taskCompleted         Boolean  @default(true) @map("task_completed")

  reminderDayBefore     Boolean  @default(false) @map("reminder_day_before")
  reminderHourBefore    Boolean  @default(false) @map("reminder_hour_before")
  reminder15MinBefore   Boolean  @default(false) @map("reminder_15_min_before")

  quietHoursStart       Int      @default(22) @map("quiet_hours_start")
  quietHoursEnd         Int      @default(8) @map("quiet_hours_end")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model Pin {
  id           String   @id @default(cuid()) @map("id")
  userId       String   @map("user_id")
  imageUrl     String   @map("image_url")
  title        String?  @map("title")
  description  String?  @map("description")
  category     String?  @map("category")
  sourceUrl    String?  @map("source_url")
  boardUrl     String?  @map("board_url")
  isCompleted  Boolean  @default(false) @map("is_completed")
  points       Int      @default(10) @map("points")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@index([boardUrl])
  @@map("pins")
}

model Task {
  id            String   @id @default(cuid()) @map("id")
  userId        String   @map("user_id")
  pinId         String?  @map("pin_id")
  title         String   @map("title")
  description   String?  @map("description")
  imageUrl      String?  @map("image_url")
  category      String?  @map("category")
  priority      String   @default("medium") @map("priority")
  status        String   @default("pending") @map("status")
  dueDate       DateTime? @map("due_date")
  reminderTime  DateTime? @map("reminder_time")
  reminderSent  Boolean  @default(false) @map("reminder_sent")
  points        Int      @default(5) @map("points")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pin           Pin?     @relation(fields: [pinId], references: [id], onDelete: SetNull)
  
  @@map("tasks")
}

model Achievement {
  id          String   @id @default(cuid()) @map("id")
  name        String   @map("name")
  description String   @map("description")
  icon        String   @map("icon")
  category    String   @map("category")
  requirement Int      @map("requirement")
  points      Int      @map("points")
  createdAt   DateTime @default(now()) @map("created_at")
  
  userAchievements UserAchievement[]
  
  @@map("achievements")
}

model UserAchievement {
  id             String   @id @default(cuid()) @map("id")
  userId         String   @map("user_id")
  achievementId  String   @map("achievement_id")
  unlockedAt     DateTime @default(now()) @map("unlocked_at")
  
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement    Achievement  @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// Admin Panel Models
model Admin {
  id           String   @id @default(cuid()) @map("id")
  username     String   @unique @map("username")
  passwordHash String   @map("password_hash")
  email        String?  @unique @map("email")
  role         String   @default("admin") @map("role")
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  logs         AdminLog[]
  
  @@map("admins")
}

model AdminLog {
  id          String   @id @default(cuid()) @map("id")
  adminId     String   @map("admin_id")
  action      String   @map("action")
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  details     String?  @map("details")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")
  
  admin       Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("admin_logs")
}

model PaymentSettings {
  id                    String   @id @default(cuid()) @map("id")
  
  starsEnabled          Boolean  @default(false) @map("stars_enabled")
  starsMonthPrice       Int      @default(299) @map("stars_month_price")
  starsYearPrice        Int      @default(1999) @map("stars_year_price")
  starsLifetimePrice    Int      @default(4999) @map("stars_lifetime_price")
  
  yookassaEnabled       Boolean  @default(false) @map("yookassa_enabled")
  yookassaShopId        String?  @map("yookassa_shop_id")
  yookassaSecretKey     String?  @map("yookassa_secret_key")
  yookassaMonthPrice    Int      @default(299) @map("yookassa_month_price")
  yookassaYearPrice     Int      @default(1999) @map("yookassa_year_price")
  yookassaLifetimePrice Int      @default(4999) @map("yookassa_lifetime_price")
  
  currency              String   @default("RUB") @map("currency")
  trialDays             Int      @default(7) @map("trial_days")
  
  updatedAt             DateTime @updatedAt @map("updated_at")
  
  @@map("payment_settings")
}

model PaymentTransaction {
  id              String   @id @default(cuid()) @map("id")
  userId          String   @map("user_id")
  amount          Int      @map("amount")
  currency        String   @default("RUB") @map("currency")
  status          String   @default("pending") @map("status")
  provider        String   @map("provider")
  providerTxId    String?  @unique @map("provider_tx_id")
  planType        String   @map("plan_type")
  metadata        String?  @map("metadata")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_transactions")
}

model AppSettings {
  id          String   @id @default(cuid()) @map("id")
  key         String   @unique @map("key")
  value       String   @map("value")
  description String?  @map("description")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("app_settings")
}

model BotLog {
  id          String   @id @default(cuid()) @map("id")
  level       String   @map("level")
  source      String   @map("source")
  message     String   @map("message")
  details     String?  @map("details")
  userId      String?  @map("user_id")
  telegramId  String?  @map("telegram_id")
  requestId   String?  @map("request_id")
  duration    Int?     @map("duration")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([level])
  @@index([source])
  @@index([createdAt])
  @@index([telegramId])
  @@map("bot_logs")
}

// Pinterest Board Sync
model PinterestBoard {
  id              String   @id @default(cuid()) @map("id")
  userId          String   @map("user_id")
  boardUrl        String   @map("board_url")
  boardName       String?  @map("board_name")
  boardUsername   String?  @map("board_username")
  lastSyncAt      DateTime? @map("last_sync_at")
  totalPins       Int      @default(0) @map("total_pins")
  newPins         Int      @default(0) @map("new_pins")
  isActive        Boolean  @default(true) @map("is_active")
  autoSync        Boolean  @default(false) @map("auto_sync")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, boardUrl])
  @@index([userId])
  @@index([boardUrl])
  @@map("pinterest_boards")
}

// Рекламные интеграции
model Ad {
  id          String   @id @default(cuid()) @map("id")
  title       String   @map("title")
  content     String   @map("content")
  imageUrl    String?  @map("image_url")
  linkUrl     String?  @map("link_url")
  buttonText  String?  @map("button_text")

  targetAll       Boolean  @default(true) @map("target_all")
  targetPremium   Boolean  @default(false) @map("target_premium")
  targetFree      Boolean  @default(false) @map("target_free")

  status      String   @default("draft") @map("status")
  scheduledAt DateTime? @map("scheduled_at")

  sentCount   Int      @default(0) @map("sent_count")
  clickCount  Int      @default(0) @map("click_count")

  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([scheduledAt])
  @@map("ads")
}

// Рассылки
model Broadcast {
  id          String   @id @default(cuid()) @map("id")
  title       String   @map("title")
  content     String   @map("content")
  imageUrl    String?  @map("image_url")

  targetAll       Boolean  @default(true) @map("target_all")
  targetPremium   Boolean  @default(false) @map("target_premium")
  targetFree      Boolean  @default(false) @map("target_free")

  status      String   @default("draft") @map("status")
  scheduledAt DateTime? @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  totalRecipients  Int  @default(0) @map("total_recipients")
  sentCount        Int  @default(0) @map("sent_count")
  failedCount      Int  @default(0) @map("failed_count")

  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  broadcastLogs BroadcastLog[]

  @@index([status])
  @@index([scheduledAt])
  @@map("broadcasts")
}

// Логи рассылок
model BroadcastLog {
  id            String   @id @default(cuid()) @map("id")
  broadcastId   String   @map("broadcast_id")
  userId        String   @map("user_id")
  telegramId    String   @map("telegram_id")
  status        String   @default("pending") @map("status")
  error         String?  @map("error")
  sentAt        DateTime? @map("sent_at")

  broadcast     Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, userId])
  @@index([broadcastId])
  @@index([status])
  @@map("broadcast_logs")
}

// Система поддержки
model SupportTicket {
  id              String   @id @default(cuid()) @map("id")
  userId          String   @map("user_id")
  telegramId      String   @map("telegram_id")
  chatId          String   @map("chat_id")

  subject         String?  @map("subject")
  category        String   @default("general") @map("category")
  priority        String   @default("normal") @map("priority")

  status          String   @default("open") @map("status")

  firstMessage    String   @map("first_message")
  lastMessage     String?  @map("last_message")
  lastMessageAt   DateTime? @map("last_message_at")
  lastMessageFrom String?  @map("last_message_from")

  assignedTo      String?  @map("assigned_to")
  assignedAt      DateTime? @map("assigned_at")
  resolvedAt      DateTime? @map("resolved_at")
  closedAt        DateTime? @map("closed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        SupportMessage[]

  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
  @@map("support_tickets")
}

// Сообщения в тикетах поддержки
model SupportMessage {
  id          String   @id @default(cuid()) @map("id")
  ticketId    String   @map("ticket_id")
  senderType  String   @map("sender_type")
  senderId    String?  @map("sender_id")
  senderName  String?  @map("sender_name")

  message     String   @map("message")
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")

  attachments String?  @map("attachments")

  createdAt   DateTime @default(now()) @map("created_at")

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
  @@map("support_messages")
}

// Сообщения бота
model BotMessage {
  id          String   @id @default(cuid()) @map("id")
  telegramId  String   @map("telegram_id")
  chatId      String   @map("chat_id")
  messageId   Int      @map("message_id")

  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([chatId, messageId])
  @@index([telegramId])
  @@index([chatId])
  @@map("bot_messages")
}

// Задачи для парсинга Pinterest
model ScraperTask {
  id              String   @id @default(cuid()) @map("id")
  userId          String   @map("user_id")
  boardUrl        String   @map("board_url")
  
  status          String   @default("pending") @map("status")
  
  totalPins       Int      @default(0) @map("total_pins")
  importedPins    Int      @default(0) @map("imported_pins")
  errorMessage    String?  @map("error_message")
  
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("scraper_tasks")
}

// Подписки пользователей
model Subscription {
  id              String   @id @default(cuid()) @map("id")
  userId          String   @map("user_id")
  
  plan            String   @map("plan")
  status          String   @default("pending") @map("status")
  
  provider        String   @map("provider")
  transactionId   String?  @map("transaction_id")
  
  amount          Int      @default(0) @map("amount")
  currency        String   @default("RUB") @map("currency")
  
  startedAt       DateTime? @map("started_at")
  expiresAt       DateTime? @map("expires_at")
  cancelledAt     DateTime? @map("cancelled_at")
  cancelledReason String?  @map("cancelled_reason")
  
  metadata        String?  @map("metadata")
  grantedBy       String?  @map("granted_by")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([startedAt])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("subscriptions")
}
